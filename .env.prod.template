# CryptoFlip Production Environment Template
# 
# WARNING: This file contains sensitive configuration.
# Copy this file to .env.prod and fill in all values.
# NEVER commit .env.prod to git.
#
# Usage:
#   cp .env.prod.template .env.prod
#   # Edit .env.prod with your actual secrets
#   # Ensure .env.prod is in .gitignore

# ============================================
# Application Settings
# ============================================
NODE_ENV=production
PORT=4000

# ============================================
# Database
# ============================================
DATABASE_URL=postgresql://cryptoflip:YOUR_SECURE_PASSWORD@postgres:5432/cryptoflip
DB_USER=cryptoflip
DB_PASSWORD=YOUR_SECURE_PASSWORD
DB_NAME=cryptoflip

# ============================================
# Redis
# ============================================
REDIS_URL=redis://redis:6379

# ============================================
# JWT Authentication
# ============================================
JWT_SECRET=YOUR_64_BYTE_BASE64_SECRET_HERE
JWT_ALGORITHM=HS256
JWT_EXPIRY=7d

# ============================================
# Blockchain / Web3
# ============================================
OPERATOR_PRIVATE_KEY=0xYOUR_OPERATOR_PRIVATE_KEY
RPC_URL_ETH=https://mainnet.infura.io/v3/YOUR_INFURA_KEY
RPC_URL_BSC=https://bsc-dataseed.binance.org
RPC_URL_POLYGON=https://polygon-mainnet.infura.io/v3/YOUR_INFURA_KEY
RPC_URL_SEPOLIA=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
CONTRACT_ADDRESS_ETH=0xYOUR_ETH_CONTRACT_ADDRESS
CONTRACT_ADDRESS_BSC=0xYOUR_BSC_CONTRACT_ADDRESS
CONTRACT_ADDRESS_POLYGON=0xYOUR_POLYGON_CONTRACT_ADDRESS
CONTRACT_ADDRESS_SEPOLIA=0xYOUR_SEPOLIA_CONTRACT_ADDRESS
PLATFORM_TREASURY_ADDRESS=0xfe6AE2a8897F262017D1B2fff6224613df1B71E2

# ============================================
# Monitoring & Alerting
# ============================================
SENTRY_DSN=https://YOUR_SENTRY_DSN@sentry.io/PROJECT_ID
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
PAGERDUTY_KEY=YOUR_PAGERDUTY_INTEGRATION_KEY
SMTP_PASSWORD=YOUR_SMTP_PASSWORD
GRAFANA_PASSWORD=YOUR_SECURE_GRAFANA_PASSWORD

# ============================================
# Cloud Provider (AWS)
# ============================================
AWS_REGION=us-east-1
AWS_S3_BUCKET=cryptoflip-backups

# ============================================
# Domain & SSL
# ============================================
DOMAIN=cryptoflip.io

# ============================================
# Security
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
CORS_ORIGINS=https://cryptoflip.io,https://www.cryptoflip.io

# ============================================
# Game Settings
# ============================================
MIN_BET=0.01
MAX_BET=1000
HOUSE_EDGE=0.01

# ============================================
# Feature Flags
# ============================================
ENABLE_WEB3=true
ENABLE_FRAUD_DETECTION=true
ENABLE_CHAT_MODERATION=true
ENABLE_RAIN_EVENTS=true
